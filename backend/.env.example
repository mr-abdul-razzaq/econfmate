PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/?appName=app-name
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ORCID OAuth Configuration
# Get your credentials from https://orcid.org/developer-tools
ORCID_CLIENT_ID=your-orcid-client-id
ORCID_CLIENT_SECRET=your-orcid-client-secret
ORCID_REDIRECT_URI=https://yourdomain.com/auth/orcid/callback

# Google OAuth Configuration
# Get your credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Email Configuration - Using Brevo (formerly Sendinblue)
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_NAME=CMS System
BREVO_SENDER_EMAIL=econfmate@gmail.com

#Cloudinary for the cloud bucket storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Paper Duplication Engine (PDE) Integration
PDE_BASE_URL=your-pde-base-url
PDE_API_KEY=your-pde-api-key-here
PDE_TIMEOUT_MS=15000
PDE_MAX_RETRIES=3
